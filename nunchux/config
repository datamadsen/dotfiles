height = 30

[app:system/journalctl]
cmd = journalctl -f
desc = Follow system logs

[app:system/powertop]
cmd = sudo powertop
desc = Power consumption

[app:system/ncdu]
cmd = ncdu
desc = Disk usage analyzer

[app:system/nvtop]
cmd = nvtop
desc = GPU monitoring

[app:system/sleep]
cmd = systemctl suspend
desc = Suspend to RAM

[app:system/reboot]
cmd = systemctl reboot
desc = Reboot system

[app:system/shutdown]
cmd = systemctl poweroff
desc = Power off system

[app:failme]
cmd = failme
desc = Test error handling

[taskrunner]
