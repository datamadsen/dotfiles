[settings]
icon_running = ●
icon_stopped = ○
toggle_shortcuts_key = ctrl-t

menu_width = 80
menu_height = 30

max_popup_width = 180
max_popup_height = 120

cache_ttl = 3600
primary_key = enter
secondary_key = tab

pane_horizontal_key = ctrl-h
pane_vertical_key = ctrl-v

[order]
